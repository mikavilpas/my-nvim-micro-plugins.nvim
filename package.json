{
  "name": "@mikavilpas/my-nvim-micro-plugins.nvim",
  "version": "1.0.0",
  "private": true,
  "description": "Some utilities that I use in my nvim config",
  "license": "MIT",
  "scripts": {
    "cy:run": "pnpm --filter ./packages/integration-tests/ cy:run",
    "dev": "pnpm --filter integration-tests dev",
    "lint": "pnpm --filter integration-tests lint",
    "markdownlint": "rumdl check",
    "prettier": "prettier --check .",
    "tui": "pnpm --filter ./packages/integration-tests/ exec tui"
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "cypress",
      "esbuild",
      "node-pty",
      "puppeteer"
    ]
  }
}
