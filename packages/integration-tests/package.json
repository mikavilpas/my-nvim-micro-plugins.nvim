    "assert": "2.1.0",
    "concurrently": "10.0.3",
    "cypress": "15.18.1",
    "eslint-plugin-no-only-tests": "3.4.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "tsx": "4.23.1",
    "type-fest": "5.8.0",
    "typescript": "6.0.3",
    "wait-on": "9.0.10",
