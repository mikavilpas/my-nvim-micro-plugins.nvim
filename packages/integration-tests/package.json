{
  "name": "@my-nvim-micro-plugins.nvim/integration-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "cy:open": "cypress open --e2e --browser=electron",
    "dev": "concurrently --kill-others --names 'app,cypress' --prefix-colors 'blue,yellow' 'pnpm tui start' 'pnpm cy:open'",
    "dev:client": "vite",
    "lint": "pnpx oxlint --type-aware && eslint --max-warnings=0 ."
  },
  "devDependencies": {
    "@catppuccin/palette": "1.8.0",
    "@tui-sandbox/library": "12.7.2",
    "@types/node": "24.13.3",
    "assert": "2.1.0",
    "concurrently": "10.0.3",
    "cypress": "15.18.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsx": "4.23.0",
    "type-fest": "5.8.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "wait-on": "9.0.10",
    "zod": "4.4.3"
  }
}
